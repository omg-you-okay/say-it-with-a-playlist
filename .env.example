# Spotify app credentials — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Loopback IP, not "localhost": Spotify rejects http://localhost redirect URIs for new apps
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# Secret for signing the session cookie — generate with: openssl rand -base64 32
SESSION_SECRET=

# Local Postgres — started with `pnpm db:up` (see docker-compose.yml).
# In production this is Neon's *pooled* URL; its ?sslmode=require is load-bearing,
# since TLS is negotiated from the connection string rather than from code.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/say_it_with_a_playlist

# Deploying? The runbook is docs/deployment.md (ADR 0016).
